{
  "name": "cknb-transfer-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "node --check server.js && node --check src/worker.js",
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "node --check server.js && node --check src/worker.js && echo 'syntax OK'",
    "models": "node -e \"fetch('http://localhost:8788/v1/models').then(r=>r.json()).then(d=>console.log(d.data.length+' models')).catch(e=>{console.error(e.message);process.exit(1)})\"",
    "deploy:worker": "wrangler deploy -c deploy/wrangler.toml"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "wrangler": "^4.0.0"
  },
  "dependencies": {
    "undici": "^8.5.0"
  }
}
