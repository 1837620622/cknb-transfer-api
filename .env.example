# 服务监听端口
PORT=8787
HOST=0.0.0.0

# 上游 unlimited.surf 地址
UPSTREAM_BASE_URL=https://unlimited.surf

# 上游 unlimited.surf 的 API key（必填）
UNLIMITED_SURF_API_KEY=ua_xxxxxxxxxxxxxxxxxxxxxxxx

# 客户端访问本服务的密钥（可选，留空则接受任意 key）
# WORKER_API_KEY=your-custom-client-key

# 默认模型（统一使用 Claude Opus 4.8）
DEFAULT_MODEL=gateway-claude-opus-4-8
DEFAULT_CLAUDE_MODEL=gateway-claude-opus-4-8

# BTL (Bad Theory Labs) 免费模型配置
# 注册地址：https://btl.uk  -> Account -> Keys
BTL_API_KEY=gw_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BTL_BASE_URL=https://api.btl.uk

# Key 池：unlimited.surf 的 key 按 IP 绑定且 unlimited，
# 服务器通过伪造 X-Forwarded-For 自动生成多个独立 key 并轮询使用，规避单 key 限速。
# 启用后 UNLIMITED_SURF_API_KEY 仅作兜底。设为 false 则只用静态 key。
KEY_POOL_ENABLED=true
KEY_POOL_SIZE=20
KEY_POOL_REFILL_THRESHOLD=5

# 代理池故障转移：proxy.scdn.io 提供免费公共代理 IP，
# 当 unlimited.surf 直连失败（5xx/超时）时自动通过代理重试，提升稳定性。
# 仅服务器版支持（Worker 版运行在 Cloudflare 边缘，无需此机制）。
PROXY_POOL_ENABLED=true
PROXY_POOL_URL=https://proxy.scdn.io/api/get_proxy.php
PROXY_POOL_PROTOCOL=http
PROXY_POOL_FETCH_COUNT=20
PROXY_POOL_REFRESH_MS=300000
PROXY_POOL_TIMEOUT_MS=8000
